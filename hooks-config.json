{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/skills/repo-memory/scripts/auto-check.sh",
            "timeout": 10000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/skills/repo-memory/scripts/post-task-check.sh",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
